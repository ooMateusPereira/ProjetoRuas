# Copie este arquivo para ".env" no servidor e preencha com o token real.
# NUNCA coloque o token real neste arquivo (.env.example) nem o envie pelo chat.
#
# Como obter o token:
#   Cloudflare Zero Trust > Networks > Tunnels > (seu túnel) > Configure
#   Em "Install and run a connector", copie o valor depois de --token

CLOUDFLARE_TUNNEL_TOKEN=cole_aqui_o_token_do_seu_tunel
